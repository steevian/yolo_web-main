# ===============================
# Cloud Deployment Env Template
# ===============================
# 用法：复制为 .env 后按实际云平台修改

# 1) 云平台注入端口（必须）
# 大多数平台会自动注入 PORT；如未自动注入可手动设置
PORT=8080
FLASK_HOST=0.0.0.0

# 2) 前端访问后端地址（必须按你的云域名修改）
# 示例（请替换 your-domain.com）：
# VITE_FLASK_BASE_URL=https://your-domain.com
VITE_FLASK_BASE_URL=https://your-domain.com

# 3) SQLite 说明（保持相对路径，不要改为本地绝对路径）
# 当前项目使用相对路径数据库文件，例如：./weed_detection.db
# 云端部署时保持相对路径策略不变。
SQLITE_DB_PATH=weed_detection.db
